# Рисунок 2.3 — Укрупненная диаграмма прецедентов сотрудников
# Layout 2x2: четыре квадранта, каждый с актором и его прецедентами

classes: {
  actor: {
    shape: rectangle
    width: 220
    height: 70
    style: {
      fill: "#c8e6c9"
      stroke: "#388e3c"
      stroke-width: 2
      border-radius: 6
      font-size: 14
      bold: true
    }
  }
  superactor: {
    shape: rectangle
    width: 220
    height: 70
    style: {
      fill: "#fff9c4"
      stroke: "#f9a825"
      stroke-width: 3
      border-radius: 6
      font-size: 14
      bold: true
    }
  }
  uc: {
    shape: oval
    width: 200
    height: 75
    style.fill: "#fff3e0"
    style.stroke: "#f57c00"
    style.font-size: 13
  }
}

# Основной контейнер с сеткой 2 столбца x 2 строки
main: "" {
  grid-columns: 2
  grid-gap: 60
  style.fill: transparent
  style.stroke: transparent

  # Квадрант 1: Оператор
  operator_zone: "" {
    style.fill: transparent
    style.stroke: transparent

    operator: "Оператор\nабонентского отдела" {class: actor}
    cli: "Управлять\nабонентами" {class: uc}
    sus: "Изменять статус\nабонента" {class: uc}
    sup: "Обрабатывать\nобращения" {class: uc}

    operator -> cli
    operator -> sus
    operator -> sup
  }

  # Квадрант 2: Финансовый
  finance_zone: "" {
    style.fill: transparent
    style.stroke: transparent

    finance: "Финансовый\nадминистратор" {class: actor}
    pl: "Управлять\nтарифами" {class: uc}
    inv: "Управлять\nсчетами" {class: uc}
    wal: "Пополнять\nлицевой счет" {class: uc}

    finance -> pl
    finance -> inv
    finance -> wal
  }

  # Квадрант 3: Сетевой
  network_zone: "" {
    style.fill: transparent
    style.stroke: transparent

    network: "Сетевой\nадминистратор" {class: actor}
    rt: "Просматривать\nмаршрутизаторы" {class: uc}
    fw: "Управлять\nбрандмауэром" {class: uc}
    sy: "Синхронизировать\nочереди" {class: uc}

    network -> rt
    network -> fw
    network -> sy
  }

  # Квадрант 4: Суперадминистратор
  super_zone: "" {
    style.fill: transparent
    style.stroke: transparent

    superadmin: "Суперадминистратор" {class: superactor}
    us: "Управлять\nсотрудниками" {class: uc}
    ro: "Управлять\nролями" {class: uc}
    rt2: "Управлять\nмаршрутизаторами" {class: uc}

    superadmin -> us
    superadmin -> ro
    superadmin -> rt2
  }
}
